---
import MainLayout from '../layouts/MainLayout.astro'
import PaidProjectCard from '../components/PaidProjectCard.astro'
import config from '../data/site-config'
import paidProjects from '../data/paid'

const title = `Projects & Products Built at Okikelabs | ${config.siteTitle}`
const description = 'Bootstrapped SaaS products and tools built at Okikelabs.'
const image = config.image.src
---

<MainLayout
	title={title}
	description={description}
	image={image}
	type="collection"
>
	<div class="mx-auto container-inner">
		<div class="mb-12">
			<h1 class="text-4xl font-extrabold mb-4">Projects</h1>
			<p class="text-lg text-copy-primary">
				I like to explore ideas through side projects — most of what I build
				comes from personal needs or things I wish existed. These are products
				I'm building at{' '}
				<a
					href="https://okikelabs.com"
					class="link"
					target="_blank"
					rel="noopener noreferrer">Okikelabs</a
				>, a bootstrapped microsaas studio I founded.
			</p>
		</div>

		<div class="grid lg:grid-cols-2 gap-4 lg:gap-6">
			{paidProjects.map((project) => <PaidProjectCard project={project} />)}
		</div>
	</div>
</MainLayout>
