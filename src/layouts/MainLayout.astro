---
import Footer from '../components/Footer.astro'
import MetaTag from '../components/MetaTag.astro'
import Navbar from '../components/Navbar.astro'

import config from '../data/site-config'

import '../styles/global.css'

interface Props {
	title: string
	description: string
	image?: string
	data?: string
	robots?: boolean
	type?: string
}

const { title, description, image, data, robots, type } = Astro.props as Props
---

<html lang="en">
	<MetaTag {title} {description} image={image} {data} {robots} {type} />
	<body>
		<div
			class="content-wrapper bg-background-primary text-copy-primary leading-normal flex flex-col min-h-screen"
		>
			<Navbar />
			<main class="grow mt-10">
				<slot />
			</main>

			<Footer />
		</div>
	</body>
</html>
