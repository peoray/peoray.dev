---
import config from '../data/site-config'
import jsonLDGenerator from '../utils/jsonLD'

interface Props {
	title: string
	description: string
	url?: URL
	image?: any
	data?: any
	robots?: boolean
	type?: string
}

const {
	title,
	description,
	url = Astro.url,
	image,
	data,
	robots,
	type,
} = Astro.props as Props

const jsonLD = jsonLDGenerator({
	type,
	post: data,
	url,
})
// Normalize canonical URL: strip .html extension and trailing slashes to match sitemap
const canonicalUrl =
	url.href.replace(/\.html$/, '').replace(/\/+$/, '') || url.href
---

<!-- SEO -->
<link rel="canonical" href={canonicalUrl} />

<!-- Open Graph -->
<meta property="og:type" content="website" />
<meta property="og:site_name" content={config.siteDescription} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:url" content={url.href} />
<meta property="og:image" content={image?.src || config.image.src} />
<meta property="og:image:url" content={image?.src || config.image.src} />
<meta property="og:image:secure_url" content={image?.src || config.image.src} />
<meta property="og:image:type" content="image/jpeg" />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="600" />
<meta property="og:image:alt" content={image?.src || config.image.alt} />

<!-- Twitter -->
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:image" content={image?.src || config.image.src} />
<meta name="twitter:image:alt" content={title} />
<meta name="twitter:domain" content={import.meta.env.SITE} />

{robots && <meta name="robots" content="noindex, nofollow" />}

<!-- JSON LD -->
<Fragment set:html={jsonLD} />
