---
import type { PaidProject } from '../data/paid'

interface Props {
	project: PaidProject
}

const { project } = Astro.props

const statusColors: Record<string, string> = {
	Active: 'bg-green-600/20 text-green-400 border-green-600/30',
	Beta: 'bg-yellow-600/20 text-yellow-400 border-yellow-600/30',
	'Coming Soon': 'bg-blue-600/20 text-blue-400 border-blue-600/30',
}

const statusClass = statusColors[project.status] ?? statusColors['Active']
---

<a
	href={project.website}
	target="_blank"
	rel="noopener noreferrer"
	class="h-auto flex flex-col justify-between border border-neutral-700 bg-background-tertiary hover:bg-background-secondary transition-all ease-out p-5 rounded-xl group"
>
	<div class="flex flex-col space-y-2">
		<div class="flex items-center justify-between">
			<h3
				class="text-xl font-bold text-purple-100 group-hover:text-purple-200 transition-colors"
			>
				{project.title}
			</h3>
			<span
				class:list={[
					'text-xs font-medium px-2.5 py-0.5 rounded-full border',
					statusClass,
				]}
			>
				{project.status}
			</span>
		</div>

		<p class="text-md text-neutral-200/80">{project.description}</p>
	</div>

