---
import type { OssProject } from '../data/oss'

interface Props {
	project: OssProject
}

const { project } = Astro.props

// Extract owner/repo from GitHub URL for the API call
const repoPath = project.source.replace('https://github.com/', '')
---

<a
	href={project.source}
	target="_blank"
	rel="nofollow noopener noreferrer"
	class="h-auto flex flex-col justify-between border border-neutral-700 bg-background-tertiary hover:bg-background-secondary transition-all ease-out p-5 rounded-xl group"
	data-repo={repoPath}
>
	<div class="flex flex-col space-y-2">
		<div class="flex items-center justify-between">
			<h3
				class="text-xl font-bold text-purple-100 group-hover:text-purple-200 transition-colors"
			>
				{project.title}
			</h3>
			<div class="flex items-center space-x-3 text-sm text-neutral-400">
				<span class="flex items-center space-x-1">
					<span class="text-yellow-500">★</span>
					<span class="star-count">{project.stars.toLocaleString()}</span>
				</span>
			</div>
		</div>

		<p class="text-md text-neutral-200/80">{project.description}</p>
	</div>

	<div class="flex flex-wrap gap-2 mt-4">
		{
			project.tech.map((tag) => (
				<span class="text-xs px-3 py-1 rounded-full bg-background-primary border border-neutral-700 text-neutral-300">
					{tag}
				</span>
			))
		}
	</div>
</a>

<script>
	// Fetch live GitHub star counts and update the DOM
	// Astro scripts are deferred by default, so DOM is ready when this runs
	;(function () {
		const cards = document.querySelectorAll('[data-repo]')
		cards.forEach(async (card) => {
			const repo = card.getAttribute('data-repo')
			if (!repo) return

			try {
				const res = await fetch(`https://api.github.com/repos/${repo}`)
				if (!res.ok) return

				const data = await res.json()
				const starEl = card.querySelector('.star-count')
				if (starEl && typeof data.stargazers_count === 'number') {
					starEl.textContent = data.stargazers_count.toLocaleString()
				}
			} catch {
				// Silently fall back to the static value
			}
		})
	})()
</script>
